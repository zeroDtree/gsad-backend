# Copy to .env for local ./mvnw spring-boot:run (not used by root docker compose).
# For Docker dev stack, copy dockers/.env.example to the repo root as .env instead.
DB_PASSWORD=change-me-db-password
REDIS_PASSWORD=change-me-redis-password
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
AGENT_PSK=change-me-agent-psk-min-16-chars
CREDENTIALS_ENCRYPTION_KEY=change-me-32-chars-minimum

# dev (default) | prod
SPRING_PROFILES_ACTIVE=dev

# Optional prod CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=
