# Copy to .env for local development with ./mvnw spring-boot:run.
# Requires PostgreSQL and Redis reachable at DB_HOST / REDIS_HOST (defaults: localhost).
DB_PASSWORD=change-me-DB_PASSWORD-at-least-32-chars
REDIS_PASSWORD=change-me-REDIS_PASSWORD-at-least-32-chars
JWT_SECRET=change-me-JWT_SECRET-at-least-32-chars
AGENT_MASTER_SECRET=change-me-AGENT_MASTER_SECRET-at-least-32-chars
CREDENTIALS_ENCRYPTION_KEY=change-me-CREDENTIALS_ENCRYPTION_KEY-at-least-32-chars

# dev (default) | prod
SPRING_PROFILES_ACTIVE=dev

# Optional prod CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=
