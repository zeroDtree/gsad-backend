# Copy to .env and set strong secrets before deploy.
DB_PASSWORD=change-me-db-password
REDIS_PASSWORD=change-me-redis-password
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
AGENT_PSK=change-me-agent-psk-min-16-chars

# dev (default) | prod
SPRING_PROFILES_ACTIVE=dev

# Public hostname for Traefik Host() rules and DNS (e.g. gsad.zerodtree.com)
GSAD_PUBLIC_HOST=gsad.example.com

# External Docker network where Traefik runs (e.g. netbird)
TRAEFIK_NETWORK=netbird

# Optional prod CORS (comma-separated origins); leave empty when frontend and API share
# the same https://${GSAD_PUBLIC_HOST} origin via Traefik
CORS_ALLOWED_ORIGINS=
